# Copy to .env and fill in strong random values.
# .env is gitignored — do not commit real passwords.

# ── Postgres ───────────────────────────────────────────────────────────
# Cluster superuser (the `postgres` role). Only infra operators know
# this; tenants never need it.
POSTGRES_ADMIN_PASSWORD=

# ── Tenant application passwords ───────────────────────────────────────
# Referenced by provisioning scripts. Each tenant also needs this
# value in its own .env (in its own repo) to connect.
PMEM_APP_PASSWORD=
TICKER_APP_PASSWORD=

# Read-only role for the public govlens.ie marketing site.
# SELECT only; cannot write; scoped to 4 whitelisted pmem tables.
GOVLENS_PUBLIC_PASSWORD=
